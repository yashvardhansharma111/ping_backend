# --- Server ---
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ping?retryWrites=true&w=majority
MONGODB_DB_NAME=ping

# --- JWT ---
# 32+ random chars each. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- OTP ---
# In dev, OTP is returned in the API response when OTP_DEBUG=true. Never enable in prod.
OTP_DEBUG=true
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=30

# --- SMS provider ---
# Set SMS_PROVIDER=stub to log OTPs to console without sending (dev/test only)
SMS_PROVIDER=renflair
RENFLAIR_API_KEY=your_renflair_api_key_here

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Razorpay (filled in M2) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
